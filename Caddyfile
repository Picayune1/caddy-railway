# This is your Caddy configuration. This default config
# opens a port and serves a static site from the www folder.
# Edit this file according to your needs.

{
    servers {
        trusted_proxies static private_ranges
    }
}

# Use :{$PORT} so Caddy listens on the port Railway expects
:{$80} {
    # 1. ALWAYS allow Railway's health check path
    # Railway's health check defaults to "/"
    handle / {
        respond "OK" 200
    }

    # 2. Restrict everything else to your IP
    @allowed_ip remote_ip 180.150.98.70
    
    handle @allowed_ip {
        reverse_proxy caldera.railway.internal:8888
    }

    # 3. Block everyone else
    handle {
        abort
    }
}
